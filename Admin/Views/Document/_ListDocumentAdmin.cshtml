@using Services.ViewModels._DocumentViewModels
@model DocumentListAdmin

<div class="card-body">
    <table class="table table-striped table-hover ">
        <thead>
            <tr>
                <th scope="col">Title</th>
                <th scope="col">Type</th>
                <th scope="col">Status</th>
                <th scope="col">Branch</th>
                <th width="15%"></th>
            </tr>
        </thead>
        <tbody>
            @foreach(var item in Model.Items)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.DocumentType.ToString()</td>
                    <td>@item.DocumentStatus.ToString()</td>
                    <td>@item.Branch</td>
                    <td>
                        <a class="btn btn-teal btn-icon" href="/document/edit/@item.Id">
                            <i class="fas fa-pencil-square"></i>
                        </a>
                        <a class="btn btn-red btn-icon" onclick="onDeleteDocument('@item.Id')">
                            <i class="fas fa-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>