@using Services.ViewModels._BorrowViewModels
@model BorrowRequestList

<div class="card-body">
    <table class="table table-striped table-hover ">
        <thead>
            <tr>
                <th scope="col">Title</th>
                <th scope="col">Type</th>
                <th scope="col">Branch</th>
                <th scope="col">Borrower</th>
                <th scope="col">Request Date</th>
                <th scope="col">Return Date</th>
                <th width="15%"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.DocumentTitle</td>
                    <td>@item.DocumentType.ToString()</td>
                    <td>@item.BranchName</td>
                    <td>@item.BorrowerName</td>
                    <td>@item.RequestDate</td>
                    <td>@item.ReturnDate</td>
                    <td>
                        <a class="btn btn-teal btn-icon" href="/document/edit/@item.BrrowRequestId">
                            <i class="fas fa-pencil-square"></i>
                        </a>
                        <a class="btn btn-red btn-icon" onclick="onDeleteDocument('@item.BrrowRequestId')">
                            <i class="fas fa-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>