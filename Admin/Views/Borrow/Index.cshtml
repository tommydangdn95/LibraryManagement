@{
    Layout = "_LayoutAdmin";
}


<header class="page-header page-header-compact page-header-light border-bottom bg-white mb-4">
    <div class="container-xl px-4">
        <div class="page-header-content">
            <div class="row align-items-center justify-content-between pt-3">
                <div class="col-auto mb-3">
                    <h1 class="page-header-title">
                        <div class="page-header-icon"><i data-feather="book-open"></i></div>
                        Borrow Management
                    </h1>
                </div>
            </div>
        </div>
    </div>
</header>
<!-- Main page content-->
<div class="container-xl px-4 mt-4">
    <nav class="nav nav-borders">
        <a class="nav-link ms-0" id="nav-new-request-tab" data-bs-toggle="tab" data-bs-target="#new-request" role="tab" aria-controls="new-request" aria-selected="true">New Request</a>
        <a class="nav-link" id="nav-approved-tab" data-bs-toggle="tab" data-bs-target="#nav-approved" role="tab" aria-controls="nav-approved" aria-selected="false">Approved</a>
        <a class="nav-link" id="nav-borrowing-tab" data-bs-toggle="tab" data-bs-target="#nav-borrowing" role="tab" aria-controls="nav-borrowing" aria-selected="false">Borrowing</a>
        <a class="nav-link" id="nav-overdue-tab" data-bs-toggle="tab" data-bs-target="#nav-overdue" role="tab" aria-controls="nav-overdue" aria-selected="false">Overdue</a>
        <a class="nav-link" id="nav-returned-tab" data-bs-toggle="tab" data-bs-target="#nav-returned" role="tab" aria-controls="nav-returned" aria-selected="false">Returned</a>
        <a class="nav-link" id="nav-canceled-tab" data-bs-toggle="tab" data-bs-target="#nav-canceled" role="tab" aria-controls="nav-canceled" aria-selected="false">Canceled</a>
        <a class="nav-link" id="nav-all-request-tab" data-bs-toggle="tab" data-bs-target="#nav-all-request" role="tab" aria-controls="nav-all-request" aria-selected="false">All Request</a>
    </nav>
    <hr class="mt-0 mb-4" />
    <div class="tab-content" id="nav-tabContent">
        <div class="tab-pane fade" id="new-request" role="tabpanel" aria-labelledby="nav-new-request-tab" tabindex="0">New Request</div>
        <div class="tab-pane fade" id="nav-approved" role="tabpanel" aria-labelledby="nav-approved-tab" tabindex="0">Approved</div>
        <div class="tab-pane fade" id="nav-borrowing" role="tabpanel" aria-labelledby="nav-borrowing-tab" tabindex="0">Borrowing</div>
        <div class="tab-pane fade" id="nav-overdue" role="tabpanel" aria-labelledby="nav-overdue-tab" tabindex="0">Overdue</div>
        <div class="tab-pane fade" id="nav-returned" role="tabpanel" aria-labelledby="nav-returned-tab" tabindex="0">Returned</div>
        <div class="tab-pane fade" id="nav-canceled" role="tabpanel" aria-labelledby="nav-canceled-tab" tabindex="0">Canceled</div>
        <div class="tab-pane fade" id="nav-all-request" role="tabpanel" aria-labelledby="nav-all-request-tab" tabindex="0">All</div>
    </div>
</div>


<div class="modal fade" id="borrowConfirmModal" tabindex="-1" aria-labelledby="borrowModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" id="borrowConfirmContent">

        </div>
    </div>
</div>


@section Scripts {
    <script src="~/js/applications/borrow/index.js"></script>
}