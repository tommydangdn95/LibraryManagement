@using Services.ViewModels._BorrowViewModels
@model BorrowRequestViewItem


<div class="modal-header">
    <h5 class="modal-title" id="exampleModalCenterTitle">Borrow Detail</h5>
    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body">
    <div class="mb-3">
        <h6 class="text-muted">Borrow Request Id</h6>
        <p>@Model.BorrowRequestId.ToString()</p>
    </div>

    <div class="mb-3">
        <h6 class="text-muted">Document</h6>
        <p>@Model.DocumentTitle</p>
    </div>

    <div class="mb-3">
        <h6 class="text-muted">Borrower</h6>
        <p>@Model.BorrowerName</p>
    </div>
    <div class="mb-3">
        <h6 class="text-muted">Request Date</h6>
        <p>@Model.RequestDate.ToString("MMM dd, yyyy")</p>
    </div>
    <div class="mb-3">
        <h6 class="text-muted">Return Date</h6>
        <p>@Model.ReturnDate.ToString("MMM dd, yyyy")</p>
    </div>
</div>
<div class="modal-footer">
    <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">Close</button>
    <button class="btn btn-primary saveChangebtn" type="button">Save changes</button>
</div>