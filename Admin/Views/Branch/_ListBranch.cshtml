@using Services.ViewModels._BranchViewModels
@model BranchList

<div class="card-body">
    <table class="table table-striped table-hover ">
        <thead>
            <tr>
                <th scope="col">Name</th>
                <th scope="col">Address</th>
                <th scope="col">Email</th>
                <th scope="col">Phone</th>
                <th width="15%"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Address</td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                    <td>
                        <a class="btn btn-warning btn-icon" href="/branch/edit/@item.BranchId">
                            <i class="fas fa-pencil-square"></i>
                        </a>
                        <a class="btn btn-red btn-icon" onclick="onDeleteBranch('@item.BranchId')">
                            <i class="fas fa-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
