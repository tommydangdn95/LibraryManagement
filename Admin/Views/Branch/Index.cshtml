@{
    Layout = "_LayoutAdmin";
}

@using Services.ViewModels._BranchViewModels
@model CreateBranch



<header class="page-header page-header-compact page-header-light border-bottom bg-white mb-4">
    <div class="container-xl px-4">
        <div class="page-header-content">
            <div class="row align-items-center justify-content-between pt-3">
                <div class="col-auto mb-3">
                    <h1 class="page-header-title">
                        <div class="page-header-icon"><i data-feather="map-pin"></i></div>
                        Branch List
                    </h1>
                </div>
            </div>
        </div>
    </div>
</header>


<div class="container-xl px-4">
    <div class="card card-header-actions mb-4">
        <div class="card-header">
            <a href="/branch/create" class="btn btn-sm btn-primary" type="button">
                Add New Branch
            </a>
        </div>
        <div id="listBranch">
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/applications/branch/index.js"></script>
}