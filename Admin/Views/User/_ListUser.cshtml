@using Services.ViewModels._UserViewModels
@model UserList


<div class="card-body">
    <table class="table table-striped table-hover ">
        <thead>
            <tr>
                <th scope="col">FullName</th>
                <th scope="col">Email</th>
                <th scope="col">Role</th>
                <th scope="col">Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var item in Model.Items)
            {
                <tr>
                    <td>@item.FullName</td>
                    <td>@item.Email</td>
                    <td>@item.Role</td>
                    @if (!item.IsSeedAdminUser)
                    {
                        <td>
                            <a class="btn btn-warning btn-icon" href="/user/edit/@item.UserId">
                                <i class="fas fa-pencil-square"></i>
                            </a>
                            <a class="btn btn-red btn-icon" onclick="onDeleteUser('@item.UserId')">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    }
                    else
                    {
                        <td></td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>