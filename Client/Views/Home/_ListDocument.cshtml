@using Services.ViewModels.Clients._DocumentViewModels
@using Services.Enums
@model DocumentList

<div class="d-flex flex-column gap-3">

    @foreach(var item in Model.Items) 
    {
        if(item.DocumentType == DocumentType.Book.ToString())
        {
            <div class="card doc-card">
                <div class="card-body d-flex gap-3 align-items-start p-3">
                    <div class="cover-placeholder flex-shrink-0"><i class="bi bi-book"></i></div>
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                            <div>
                                <h6 class="mb-1 fw-semibold">@item.DocumentTitle</h6>
                                <p class="text-muted small mb-2">Published: @item.FormatPublishDate &nbsp;·&nbsp; Branch: @item.Branch</p>
                            </div>
                        </div>
                        <p class="small text-muted mb-2" style="line-height:1.5">@item.DocumentDescription</p>
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                            <div class="d-flex gap-2">
                                <span class="badge badge-type rounded-pill">@item.DocumentType</span>
                            </div>
                            @if (item.IsAvaiableBorrowRequest)
                            {
                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3" onclick="onShowBorrowRequest('@item.DocumentId')">
                                    <i class="bi bi-send me-1"></i>Borrow Request
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" disabled>
                                    <i class="bi bi-x-circle me-1"></i>
                                    Unavailable
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (item.DocumentType == DocumentType.NewsPaper.ToString())
        {
            <div class="card doc-card">
                <div class="card-body d-flex gap-3 align-items-start p-3">
                    <div class="cover-placeholder flex-shrink-0" style="background:linear-gradient(135deg,#fce7f3,#fbcfe8);"><i class="bi bi-newspaper" style="color:#be185d;"></i></div>
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                            <div>
                                <h6 class="mb-1 fw-semibold">@item.DocumentTitle</h6>
                                <p class="text-muted small mb-2">Published: @item.FormatPublishDate &nbsp;·&nbsp; Branch: @item.Branch</p>
                            </div>
                        </div>
                        <p class="small text-muted mb-2" style="line-height:1.5">@item.DocumentDescription</p>
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                            <div class="d-flex gap-2">
                                <span class="badge badge-type rounded-pill">@item.DocumentType</span>
                            </div>
                            @if (item.IsAvaiableBorrowRequest)
                            {
                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3" onclick="onShowBorrowRequest('@item.DocumentId')">
                                    <i class="bi bi-send me-1"></i>Borrow Request
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" disabled>
                                    <i class="bi bi-x-circle me-1"></i>
                                    Unavailable
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (item.DocumentType == DocumentType.Magazine.ToString())
        {
            <div class="card doc-card">
                <div class="card-body d-flex gap-3 align-items-start p-3">
                    <div class="cover-placeholder flex-shrink-0" style="background:linear-gradient(135deg,#d1fae5,#a7f3d0);"><i class="bi bi-file-earmark-text" style="color:#065f46;"></i></div>
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                            <div>
                                <h6 class="mb-1 fw-semibold">@item.DocumentTitle</h6>
                                <p class="text-muted small mb-2">Published: @item.FormatPublishDate &nbsp;·&nbsp; Branch: @item.Branch</p>
                            </div>
                        </div>
                        <p class="small text-muted mb-2" style="line-height:1.5">@item.DocumentDescription</p>
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                            <div class="d-flex gap-2">
                                <span class="badge badge-type rounded-pill">@item.DocumentType</span>
                            </div>
                            @if (item.IsAvaiableBorrowRequest)
                            {
                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3" onclick="onShowBorrowRequest('@item.DocumentId')">
                                    <i class="bi bi-send me-1"></i>Borrow Request
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" disabled>
                                    <i class="bi bi-x-circle me-1"></i>
                                    Unavailable
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

    }

</div>