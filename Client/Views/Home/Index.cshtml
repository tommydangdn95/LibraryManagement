@{
    ViewData["Title"] = "Home Page";
    Layout = "_LayoutAdmin";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}

@using Services.ViewModels.Clients._DocumentViewModels
@using Services.Utils
@model DocumentListQuery

<div class="row g-4">

    <!-- ===== FILTER SIDEBAR ===== -->
    <div class="col-lg-3">
        <div class="card filter-card">
            <div class="card-header d-flex justify-content-between align-items-center py-3 px-3">
                <span><i class="bi bi-funnel me-2 text-primary"></i>Filters</span>
                <button class="btn btn-sm btn-link btn-reset p-0 text-danger text-decoration-none">Reset all</button>
            </div>
            <div class="card-body px-3 py-3">

                <!-- Search -->
                <div class="filter-divider">Search</div>
                <div class="input-group search-bar">
                    <span class="input-group-text"><i class="bi bi-search text-muted"></i></span>
                    <input asp-for="SearchDocumentName" type="text" class="form-control form-control-sm" placeholder="Document title..." />
                </div>

                <!-- Branch -->
                <div class="filter-divider mt-3">Branch</div>
                <select asp-for="BranchId" asp-items="Model.BranchListItem" class="form-select form-select-sm">
                    <option value="">-- All branches --</option>
                </select>

                <!-- Document Type -->
                <div class="filter-divider mt-3">Document Type</div>
                <div class="d-flex flex-column gap-1" id="listDocumentType">
                    @foreach (var (documentType, index) in Model.ListDocumentType.WithIndex())
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="@documentType.value" id="doc_@(documentType.value)_@index" />
                            <label class="form-check-label small" for="doc_@(documentType.value)_@index">
                                <i class="bi bi-book text-primary me-1"></i>
                                @documentType.label
                            </label>
                        </div>
                    }
                </div>


                <!-- Availability -->
                <div class="filter-divider mt-3">Availability</div>
                <div class="d-flex flex-column gap-1" id="listBorrowStatusDisplay">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="borrowStatus" id="availAll" checked />
                        <label class="form-check-label small" for="availAll">All</label>
                    </div>
                    @foreach (var (borrowStatus, index) in Model.ListBorrowStatus.WithIndex())
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="radio" value="@borrowStatus.value" name="borrowStatus" id="borrow_@(borrowStatus.value)_@index" />
                            <label class="form-check-label small" for="borrow_@(borrowStatus.value)_@index">@borrowStatus.label</label>
                        </div>
                    } 
                </div>

                <!-- Publish Date Range -->
                <div class="filter-divider mt-3">Publish Date</div>
                <div class="d-flex flex-column gap-2">
                    <div>
                        <label class="form-label small text-muted mb-1" for="StartDate">From</label>
                        <input type="date" class="form-control form-control-sm" asp-for="StartDate" />
                    </div>
                    <div>
                        <label class="form-label small text-muted mb-1" for="EndDate">To</label>
                        <input type="date" class="form-control form-control-sm" asp-for="EndDate" />
                    </div>
                </div>

                <button class="btn btn-primary btn-sm w-100 mt-3" id="filterBtn">
                    <i class="bi bi-search me-1"></i>Apply Filters
                </button>

            </div>
        </div>
    </div>

    <!-- ===== DOCUMENT LIST ===== -->
    <div class="col-lg-9">

        <!-- Sort bar -->
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-primary">All</button>
                <button class="btn btn-sm btn-outline-secondary">Books</button>
                <button class="btn btn-sm btn-outline-secondary">Magazines</button>
                <button class="btn btn-sm btn-outline-secondary">Thesis</button>
            </div>
            <select class="form-select form-select-sm w-auto">
                <option>Sort: Newest</option>
                <option>Sort: Oldest</option>
                <option>Sort: Title A–Z</option>
                <option>Sort: Title Z–A</option>
            </select>
        </div>

        <div id="listDocument">
        </div>
    </div>
</div>

<!-- ===== BORROW REQUEST MODAL ===== -->
<div class="modal fade" id="borrowModal" tabindex="-1" aria-labelledby="borrowModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" id="borrowModalContent">
        </div>
  </div>
</div>
<!-- /BORROW REQUEST MODAL -->


@section Scripts {
    <script src="~/js/applications/home/index.js"></script>
}