@{
    Layout = "_LayoutAdmin";
}


@section Styles {
    <link rel="stylesheet" href="~/css/borrow.css" />
}

<!-- Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="page-title mb-0"><i class="bi bi-bookmark me-2"></i>My Borrow Records</h4>
        <p class="text-muted small mb-0 mt-1">Track and manage your borrowed documents</p>
    </div>
</div>

<!-- Stat cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card stat-card p-3">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#e0e7ff;"><i class="bi bi-hourglass-split" style="color:#4338ca;"></i></div>
                <div><div class="fw-bold fs-4 lh-1">3</div><div class="text-muted small">Pending</div></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card p-3">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#d1fae5;"><i class="bi bi-book-fill" style="color:#065f46;"></i></div>
                <div><div class="fw-bold fs-4 lh-1">5</div><div class="text-muted small">Active</div></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card p-3">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#fee2e2;"><i class="bi bi-exclamation-triangle-fill" style="color:#dc2626;"></i></div>
                <div><div class="fw-bold fs-4 lh-1">1</div><div class="text-muted small">Overdue</div></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card p-3">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#f3f4f6;"><i class="bi bi-check2-circle" style="color:#6b7280;"></i></div>
                <div><div class="fw-bold fs-4 lh-1">24</div><div class="text-muted small">Returned</div></div>
            </div>
        </div>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-3" id="borrowTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="nav-all-request-tab" data-bs-toggle="tab" data-bs-target="#all-request" type="button" role="tab" aria-controls="all-request" aria-selected="true">All</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="nav-new-request-tab" data-bs-toggle="tab" data-bs-target="#new-request" type="button" role="tab" aria-controls="new-request" aria-selected="false">Pending</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="nav-approved-tab" data-bs-toggle="tab" data-bs-target="#approved-request" type="button" role="tab" aria-controls="approved-request" aria-selected="false">Approved</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="nav-borrowing-tab" data-bs-toggle="tab" data-bs-target="#borrowing-request" type="button" role="tab" aria-controls="borrowing-request" aria-selected="false">Borrowing</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="nav-overdue-tab" data-bs-toggle="tab" data-bs-target="#overdue-request" type="button" role="tab" aria-controls="overdue-request" aria-selected="false">Overdue</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="nav-returned-tab" data-bs-toggle="tab" data-bs-target="#returned-request" type="button" role="tab" aria-controls="returned-request" aria-selected="false">Returned</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="nav-canceled-tab" data-bs-toggle="tab" data-bs-target="#canceled-request" type="button" role="tab" aria-controls="canceled-request" aria-selected="false">Canceled</button>
    </li>
</ul>

<!-- Search & sort -->
<div class="d-flex gap-2 mb-3 flex-wrap">
    <div class="input-group input-group-sm" style="max-width:280px;">
        <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
        <input type="text" class="form-control" placeholder="Search title..." id="searchInput" />
    </div>
    <select class="form-select form-select-sm w-auto">
        <option>Sort: Newest</option>
        <option>Sort: Oldest</option>
        <option>Sort: Due Soon</option>
    </select>
</div>

<div class="tab-content" id="nav-tabContent">
    <div class="tab-pane fade" id="all-request" role="tabpanel" aria-labelledby="nav-all-request-tab" tabindex="0">All Request</div>
    <div class="tab-pane fade" id="new-request" role="tabpanel" aria-labelledby="nav-new-request-tab" tabindex="0">New Submitted</div>
    <div class="tab-pane fade" id="approved-request" role="tabpanel" aria-labelledby="nav-approved-tab" tabindex="0">Approved</div>
    <div class="tab-pane fade" id="borrowing-request" role="tabpanel" aria-labelledby="nav-borrowing-tab" tabindex="0">Borrowing</div>
    <div class="tab-pane fade" id="overdue-request" role="tabpanel" aria-labelledby="nav-overdue-tab" tabindex="0">Overdue</div>
    <div class="tab-pane fade" id="returned-request" role="tabpanel" aria-labelledby="nav-returned-tab" tabindex="0">Returned</div>
    <div class="tab-pane fade" id="canceled-request" role="tabpanel" aria-labelledby="nav-canceled-tab" tabindex="0">Canceled</div>
</div>

<div id="borrowList" class="d-flex flex-column gap-3">
</div>
@section Scripts {
    <script src="~/js/applications/borrow/index.js"></script>
}